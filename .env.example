TURNSTILE_APP_NAME=Turnstile
TURNSTILE_ENV=development
TURNSTILE_REDIS_URL=redis://redis:6379/2
TURNSTILE_CELERY_BROKER_URL=redis://redis:6379/0
TURNSTILE_CELERY_RESULT_BACKEND=redis://redis:6379/1
TURNSTILE_RUNTIME_MODE=stub
TURNSTILE_STUB_TASK_DELAY_S=0.2
TURNSTILE_DOCKER_HOST=
TURNSTILE_DOCKER_NETWORK=turnstile_default
TURNSTILE_DOCKER_SERVICE_HOST=127.0.0.1
TURNSTILE_RUNTIME_HEARTBEAT_INTERVAL_S=1.0
